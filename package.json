{
  "name": "@aardworx/wombat.base",
  "version": "0.3.2",
  "description": "Math and geometry primitives for the Wombat TypeScript stack — vectors, matrices, quaternions, transformations, bounding boxes, and packed array views, with TypedArray-backed precision. Port of F# Aardvark.Base.",
  "license": "MIT",
  "author": "krauthaufen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krauthaufen/wombat.base.git"
  },
  "homepage": "https://github.com/krauthaufen/wombat.base",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "wombat",
    "aardvark",
    "math",
    "geometry",
    "vector",
    "matrix",
    "quaternion",
    "linear-algebra"
  ],
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./font": {
      "types": "./dist/font/index.d.ts",
      "import": "./dist/font/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tspc -p tsconfig.build.json",
    "typecheck": "node scripts/typecheck.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "ts-patch install -s",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@boperators/plugin-ts-language-server": "^0.3.2",
    "@boperators/plugin-tsc": "^0.3.2",
    "@boperators/plugin-vite": "^0.3.2",
    "@types/node": "^20.11.0",
    "@types/opentype.js": "^1.3.9",
    "boperators": "^0.3.2",
    "ts-patch": "^3.1.2",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "dependencies": {
    "opentype.js": "^1.3.5"
  }
}
